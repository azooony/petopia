{
  "name": "petopia",
  "version": "1.0.0",
  "main": "dist/server.js",
  "license": "ISC",
  "scripts": {
    "predev": "node scripts/kill-port.js",
    "dev": "concurrently --kill-others-on-fail --names \"api,ai\" --prefix-colors \"cyan,magenta\" \"ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts\" \"py -3.12 ai-service/app.py\"",
    "test-db": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/config/test-db.ts",
    "build": "tsc",
    "start": "node -r tsconfig-paths/register dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^10.0.0",
    "prisma": "^7.8.0",
    "prisma-erd-generator": "^2.4.2",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/cors": "^2.8.19",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  }
}
