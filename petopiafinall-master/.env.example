# Copy this file to .env and fill in real values before running the server.
# NEVER commit .env to version control.

# PostgreSQL connection string (Prisma uses this)
DATABASE_URL="postgresql://postgres:password@localhost:5432/petopia_db"

# Express server port
PORT=3000

# JWT signing secret — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_before_deploying

# Comma-separated list of allowed CORS origins for browser clients.
# Flutter mobile apps do not use CORS, so this only matters for web builds.
FRONTEND_URL=http://localhost:5173
